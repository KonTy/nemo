[Nemo Action]

# Compress selected files/folders to an archive
Active=true

Name=Compress to 7z Archive
Comment=Create a compressed .7z archive from selected files

# Use 7z to create archive in the parent directory
Exec=<compress-to-7z.sh %F>

Icon-Name=package-x-generic

# Show for any number of selected files/folders (at least one)
Selection=notnone

# Show for all file types
Extensions=any;

# Only show if 7z is available
Conditions=exec 7z;
