[Nemo Action]

# Compress selected files/folders to an archive
Active=true

Name=Compress to Archive
Comment=Create a compressed .tar.gz archive with progress

# Use tar + pv + gzip to create archive in the parent directory
Exec=<compress-to-archive.sh %F>

Icon-Name=package-x-generic

# Show for any number of selected files/folders (at least one)
Selection=notnone

# Show for all file types
Extensions=any;

# Only show if required tools are available
Dependencies=tar;pv;gzip;zenity;
